<!DOCTYPE html>
<html lang="en">
    <%- include('./partials/head.ejs',{Title:"Text Share"}) %>
<body>
    <%- include('./partials/navbar.ejs',{active4:"active",active1:"",active2:"",active3:""}) %>

    
    <div class="container">
      
        <div class="row">
          <form action="/Text/save" method="post" id="textForm">
            <input type="hidden" name="textId" value="<%= typeof textId !== 'undefined' ? textId : '' %>">
            <div class="textarea-wrapper" style="position: relative;">
              <!-- Copy to clipboard button (top-right of textarea) -->
              <button
                type="button"
                id="copyBtn"
                class="copy-btn"
                title="Copy to clipboard"
                style="position: absolute; top: 10px; right: 10px; padding: 6px 10px; font-size: 0.85rem; border-radius: 6px; border: none; background-color: #2d2d2d; color: #e5e5e5; cursor: pointer; z-index: 2;"
              >
                Copy
              </button>

              <div id="editorSurface" style="position: relative; border: 1px solid #323232; border-radius: 8px; background: #151515;">
                <div
                  id="contentEditor"
                  contenteditable="true"
                  spellcheck="false"
                  style="font-size: large; width: 100%; min-height: 360px; max-height: 62vh; overflow: auto; padding: 14px; color: #ececec; outline: none; white-space: pre-wrap; word-break: break-word;"
                ><%=content%></div>
                <div id="remoteCursorLayer" style="position: absolute; inset: 0; pointer-events: none;"></div>
              </div>
              <textarea id="content" name="content" style="display: none;"><%=content%></textarea>

              <!-- Live cursor position (line/column) -->
              <div
                id="cursorInfo"
                style="position: absolute; bottom: 8px; right: 12px; font-size: 0.8rem; color: #a0a0a0; pointer-events: none;"
              >
                Line 1, Col 1
              </div>
            </div>

            <!-- Autosave status -->
            <div id="saveStatus" style="margin-top: 4px; font-size: 0.85rem; color: #a0a0a0;">
              Autosave: idle
            </div>
            <div id="collabStatus" style="margin-top: 6px; font-size: 0.85rem; color: #a0a0a0;">
              Live users: connecting...
            </div>
            <div id="liveUsers" style="display: flex; gap: 6px; flex-wrap: wrap; margin-top: 8px;"></div>
            <div id="liveActivity" style="margin-top: 8px; font-size: 0.85rem; color: #b5b5b5;"></div>
            <!-- save button -->

            <div class="save-lock-btn">
            
                <button type="submit" class="bookmarkBtn">
                    <span class="IconContainer">
                      <svg viewBox="0 0 384 512" height="0.9em" class="icon">
                        <path
                          d="M0 48V487.7C0 501.1 10.9 512 24.3 512c5 0 9.9-1.5 14-4.4L192 400 345.7 507.6c4.1 2.9 9 4.4 14 4.4c13.4 0 24.3-10.9 24.3-24.3V48c0-26.5-21.5-48-48-48H48C21.5 0 0 21.5 0 48z"
                        ></path>
                      </svg>
                      
                    </span>
                    <p  class="text">Save</p>
                  </button>
                <% if(lockButton) {%>
                  <button type="button" class="bookmarkBtn2" id="showPopup">
                    <span class="IconContainer2">
                      <svg class="svg-icon2" viewBox="0 0 20 20">
                                              <path d="M17.308,7.564h-1.993c0-2.929-2.385-5.314-5.314-5.314S4.686,4.635,4.686,7.564H2.693c-0.244,0-0.443,0.2-0.443,0.443v9.3c0,0.243,0.199,0.442,0.443,0.442h14.615c0.243,0,0.442-0.199,0.442-0.442v-9.3C17.75,7.764,17.551,7.564,17.308,7.564 M10,3.136c2.442,0,4.43,1.986,4.43,4.428H5.571C5.571,5.122,7.558,3.136,10,3.136 M16.865,16.864H3.136V8.45h13.729V16.864z M10,10.664c-0.854,0-1.55,0.696-1.55,1.551c0,0.699,0.467,1.292,1.107,1.485v0.95c0,0.243,0.2,0.442,0.443,0.442s0.443-0.199,0.443-0.442V13.7c0.64-0.193,1.106-0.786,1.106-1.485C11.55,11.36,10.854,10.664,10,10.664 M10,12.878c-0.366,0-0.664-0.298-0.664-0.663c0-0.366,0.298-0.665,0.664-0.665c0.365,0,0.664,0.299,0.664,0.665C10.664,12.58,10.365,12.878,10,12.878"></path>
                                          </svg>
                    </span>
                    <p class="text">Lock</p>
                  </button>
                  <% } %>
            </div>
            </form>
            <form >
            <div id="popup" class="popup">
              <h1 style="text-decoration: bold;">Do you want to Lock this page content ??</h1>
              <p>Locking this page disable other public users to see the content written</p>
              <input type="text" name="passkey" id="passkey" placeholder="Enter a passkey to Lock" style="margin-top: 10px; padding: 10px; width: 95%; background-color: #1E1E1E; border-radius: 12px; color: #709f44;" >
              <input type="hidden" name="textId" value="<%= typeof textId !== 'undefined' ? textId : '' %>">
              
              <div class="lock-cancel-btn">
                <!-- <button type="button" id="hidePopup">Cancel</button> -->
                <!-- <button type="submit" id="lock" formaction="/Text/lock" formmethod="post" >Lock</button>
                 -->
                 <button class="bookmarkBtn" type="button" id="hidePopup">
                  <span class="IconContainer">
                    <svg class="svg-icon" viewBox="0 0 20 20">
                              <path d="M10.185,1.417c-4.741,0-8.583,3.842-8.583,8.583c0,4.74,3.842,8.582,8.583,8.582S18.768,14.74,18.768,10C18.768,5.259,14.926,1.417,10.185,1.417 M10.185,17.68c-4.235,0-7.679-3.445-7.679-7.68c0-4.235,3.444-7.679,7.679-7.679S17.864,5.765,17.864,10C17.864,14.234,14.42,17.68,10.185,17.68 M10.824,10l2.842-2.844c0.178-0.176,0.178-0.46,0-0.637c-0.177-0.178-0.461-0.178-0.637,0l-2.844,2.841L7.341,6.52c-0.176-0.178-0.46-0.178-0.637,0c-0.178,0.176-0.178,0.461,0,0.637L9.546,10l-2.841,2.844c-0.178,0.176-0.178,0.461,0,0.637c0.178,0.178,0.459,0.178,0.637,0l2.844-2.841l2.844,2.841c0.178,0.178,0.459,0.178,0.637,0c0.178-0.176,0.178-0.461,0-0.637L10.824,10z"></path>
                            </svg>
                  </span>
                  <p class="text">Cancel</p>
                </button>

                 <button type="submit" class="bookmarkBtn2" id="lock" formaction="/Text/lock" formmethod="post">
                  <span class="IconContainer2">
                    <svg class="svg-icon2" viewBox="0 0 20 20">
                                            <path d="M17.308,7.564h-1.993c0-2.929-2.385-5.314-5.314-5.314S4.686,4.635,4.686,7.564H2.693c-0.244,0-0.443,0.2-0.443,0.443v9.3c0,0.243,0.199,0.442,0.443,0.442h14.615c0.243,0,0.442-0.199,0.442-0.442v-9.3C17.75,7.764,17.551,7.564,17.308,7.564 M10,3.136c2.442,0,4.43,1.986,4.43,4.428H5.571C5.571,5.122,7.558,3.136,10,3.136 M16.865,16.864H3.136V8.45h13.729V16.864z M10,10.664c-0.854,0-1.55,0.696-1.55,1.551c0,0.699,0.467,1.292,1.107,1.485v0.95c0,0.243,0.2,0.442,0.443,0.442s0.443-0.199,0.443-0.442V13.7c0.64-0.193,1.106-0.786,1.106-1.485C11.55,11.36,10.854,10.664,10,10.664 M10,12.878c-0.366,0-0.664-0.298-0.664-0.663c0-0.366,0.298-0.665,0.664-0.665c0.365,0,0.664,0.299,0.664,0.665C10.664,12.58,10.365,12.878,10,12.878"></path>
                                        </svg>
                  </span>
                  <p class="text">Lock</p>
                </button>
              </div>
            

            </div>
            </form>
           
              
            <!-- Overlay div -->
            <div id="overlay" class="overlay"></div>

            <!-- Warning Popup -->
            <div id="warningPopup" class="popup" style="display: none;">
                <h1 style="text-decoration: bold; color: beige; margin-bottom: 20px;">⚠️ Important Notice</h1>
                <p style="color: beige; font-size: 1.1em; line-height: 1.6; margin-bottom: 30px;">
                    This website is made for Speed Sharing purpose. Please do not use it for Storing Data, your data won't be available after 30 days. Make sure you have backed up your data.
                </p>
                <div class="lock-cancel-btn" style="position: relative; bottom: auto; right: auto; margin-top: 20px; justify-content: center;">
                    <button class="bookmarkBtnUnderstand" type="button" id="hideWarningPopup">
                        <span class="IconContainerUnderstand">
                            <svg class="svg-icon" viewBox="0 0 20 20" style="width: 1.2em; height: 1.2em;">
                                <path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293l-3 3a1 1 0 01-1.414 0l-1.5-1.5a1 1 0 011.414-1.414L9 9.586l2.293-2.293a1 1 0 011.414 1.414z" fill="white"></path>
                            </svg>
                        </span>
                        <p class="textUnderstand">I Understand</p>
                    </button>
                </div>
            </div>
            <!-- Warning Overlay -->
            <div id="warningOverlay" class="overlay" style="display: none;"></div>

        </div>
    </div>
    
    <script src="/socket.io/socket.io.js"></script>
    <script>
      const renderedTextId = "<%= typeof textId !== 'undefined' ? textId : '' %>";
      const textId = renderedTextId || window.location.pathname.split('/').filter(Boolean).pop() || "";
      const showPopupBtn = document.getElementById('showPopup');
      const hidePopupBtn = document.getElementById('hidePopup');
      const popup = document.getElementById('popup');
      const overlay = document.getElementById('overlay');
      const warningPopup = document.getElementById('warningPopup');
      const warningOverlay = document.getElementById('warningOverlay');
      const hideWarningPopup = document.getElementById('hideWarningPopup');

      if (showPopupBtn && popup && overlay) {
        showPopupBtn.addEventListener("click", () => {
          popup.style.display = 'block';
          overlay.style.display = 'block';
        });
      }

      if (hidePopupBtn && popup && overlay) {
        hidePopupBtn.addEventListener("click", () => {
          popup.style.display = 'none';
          overlay.style.display = 'none';
        });
      }

      if (hideWarningPopup && warningPopup && warningOverlay) {
        hideWarningPopup.addEventListener("click", () => {
          warningPopup.style.display = 'none';
          warningOverlay.style.display = 'none';
        });
      }

      window.addEventListener('DOMContentLoaded', function() {
        if (warningPopup && warningOverlay) {
          warningPopup.style.display = 'block';
          warningOverlay.style.display = 'block';
        }

        const hiddenTextarea = document.getElementById('content');
        const editor = document.getElementById('contentEditor');
        const editorSurface = document.getElementById('editorSurface');
        const remoteCursorLayer = document.getElementById('remoteCursorLayer');
        const cursorInfo = document.getElementById('cursorInfo');
        const saveStatus = document.getElementById('saveStatus');
        const collabStatus = document.getElementById('collabStatus');
        const liveUsers = document.getElementById('liveUsers');
        const liveActivity = document.getElementById('liveActivity');
        const copyBtn = document.getElementById('copyBtn');
        let autoSaveTimeout = null;
        let emitChangeTimeout = null;
        let isApplyingRemote = false;
        let lastSavedContent = hiddenTextarea ? hiddenTextarea.value : '';
        let selfUserId = null;
        let collaborators = [];
        const socket = io();

        function getEditorText() {
          if (!editor) return "";
          return editor.innerText.replace(/\r\n/g, '\n');
        }

        function syncHiddenTextarea() {
          if (hiddenTextarea) hiddenTextarea.value = getEditorText();
        }

        function createRangeAtOffset(offset) {
          if (!editor) return null;
          const walker = document.createTreeWalker(editor, NodeFilter.SHOW_TEXT);
          let node = walker.nextNode();
          let remaining = Math.max(0, offset);

          while (node) {
            const len = node.textContent.length;
            if (remaining <= len) {
              const range = document.createRange();
              range.setStart(node, remaining);
              range.collapse(true);
              return range;
            }
            remaining -= len;
            node = walker.nextNode();
          }

          const fallback = document.createRange();
          fallback.selectNodeContents(editor);
          fallback.collapse(false);
          return fallback;
        }

        function getCursorPosition() {
          if (!editor) return 0;
          const selection = window.getSelection();
          if (!selection || selection.rangeCount === 0) return 0;
          const range = selection.getRangeAt(0);
          if (!editor.contains(range.endContainer)) return 0;
          const pre = range.cloneRange();
          pre.selectNodeContents(editor);
          pre.setEnd(range.endContainer, range.endOffset);
          return pre.toString().length;
        }

        function setCursorPosition(offset) {
          if (!editor) return;
          const range = createRangeAtOffset(offset);
          if (!range) return;
          const selection = window.getSelection();
          selection.removeAllRanges();
          selection.addRange(range);
        }

        function lineAndColFromPos(value, pos) {
          const textUptoCursor = value.substring(0, pos);
          const lines = textUptoCursor.split('\n');
          return { line: lines.length, col: lines[lines.length - 1].length + 1 };
        }

        function updateCursorInfo() {
          if (!editor || !cursorInfo) return;
          const info = lineAndColFromPos(getEditorText(), getCursorPosition());
          cursorInfo.textContent = `Line ${info.line}, Col ${info.col}`;
        }

        function setSaveStatus(message) {
          if (saveStatus) saveStatus.textContent = message;
        }

        function setActivity(message) {
          if (liveActivity) liveActivity.textContent = message;
        }

        function getCaretRectAtOffset(offset) {
          const range = createRangeAtOffset(offset);
          if (!range) return null;
          const directRect = range.getClientRects()[0];
          if (directRect) return directRect;

          const marker = document.createElement('span');
          marker.textContent = '\u200b';
          range.insertNode(marker);
          const markerRect = marker.getBoundingClientRect();
          marker.remove();
          return markerRect;
        }

        function renderRemoteCursors() {
          if (!remoteCursorLayer || !editorSurface || !editor) return;
          remoteCursorLayer.innerHTML = '';
          const surfaceRect = editorSurface.getBoundingClientRect();
          const textValue = getEditorText();

          collaborators.forEach((user) => {
            if (!user || user.id === selfUserId) return;
            const offset = Math.max(0, Math.min(user.cursor || 0, textValue.length));
            const caretRect = getCaretRectAtOffset(offset);
            if (!caretRect) return;

            const x = Math.max(0, caretRect.left - surfaceRect.left);
            const y = Math.max(0, caretRect.top - surfaceRect.top);
            const h = Math.max(16, caretRect.height || 18);

            const cursorEl = document.createElement('div');
            cursorEl.style.position = 'absolute';
            cursorEl.style.left = `${x}px`;
            cursorEl.style.top = `${y}px`;
            cursorEl.style.width = '2px';
            cursorEl.style.height = `${h}px`;
            cursorEl.style.background = user.color || '#22c55e';
            cursorEl.style.borderRadius = '2px';

            const labelEl = document.createElement('div');
            labelEl.textContent = user.name || 'Anonymous';
            labelEl.style.position = 'absolute';
            labelEl.style.left = `${x + 4}px`;
            labelEl.style.top = `${Math.max(0, y - 20)}px`;
            labelEl.style.fontSize = '0.68rem';
            labelEl.style.padding = '1px 6px';
            labelEl.style.borderRadius = '8px';
            labelEl.style.color = '#fff';
            labelEl.style.background = user.color || '#22c55e';
            labelEl.style.whiteSpace = 'nowrap';

            remoteCursorLayer.appendChild(cursorEl);
            remoteCursorLayer.appendChild(labelEl);
          });
        }

        function renderCollaborators() {
          if (!liveUsers || !collabStatus || !editor) return;
          const textValue = getEditorText();
          collabStatus.textContent = `Live users: ${collaborators.length}`;
          liveUsers.innerHTML = collaborators.map((user) => {
            const cursor = lineAndColFromPos(textValue, user.cursor || 0);
            const you = user.id === selfUserId ? ' (You)' : '';
            return `<span style="padding: 4px 8px; border-radius: 999px; background: ${user.color}22; border: 1px solid ${user.color}; color: #f5f5f5; font-size: 0.8rem;">${user.name}${you} - L${cursor.line}:C${cursor.col}</span>`;
          }).join('');
          renderRemoteCursors();
        }

        function emitCursorMove() {
          socket.emit("cursor:move", { textId, cursor: getCursorPosition() });
        }

        function emitTextChange() {
          socket.emit("text:change", {
            textId,
            content: getEditorText(),
            cursor: getCursorPosition(),
          });
        }

        async function autoSave() {
          if (!editor) return;
          const currentContent = getEditorText();
          if (currentContent === lastSavedContent) return;

          setSaveStatus('Autosave: saving...');
          try {
            const body = new URLSearchParams();
            body.append('content', currentContent);
            body.append('textId', textId);

            const response = await fetch('/Text/save', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest',
              },
              body: body.toString(),
            });

            if (!response.ok) {
              setSaveStatus(`Autosave: error (${response.status})`);
              return;
            }

            lastSavedContent = currentContent;
            setSaveStatus('Autosave: saved');
          } catch (e) {
            setSaveStatus('Autosave: error (connection)');
          }
        }

        function scheduleAutoSave() {
          setSaveStatus('Autosave: pending...');
          if (autoSaveTimeout) clearTimeout(autoSaveTimeout);
          autoSaveTimeout = setTimeout(autoSave, 1600);
        }

        if (editor) {
          const initialText = hiddenTextarea ? hiddenTextarea.value : getEditorText();
          editor.textContent = initialText || '';
          syncHiddenTextarea();

          editor.addEventListener('paste', (event) => {
            event.preventDefault();
            const text = (event.clipboardData || window.clipboardData).getData('text');
            document.execCommand('insertText', false, text);
          });

          editor.addEventListener('input', () => {
            if (isApplyingRemote) return;
            const cursor = getCursorPosition();
            const normalized = getEditorText();
            editor.textContent = normalized;
            setCursorPosition(Math.min(cursor, normalized.length));
            syncHiddenTextarea();
            updateCursorInfo();
            scheduleAutoSave();
            emitCursorMove();
            if (emitChangeTimeout) clearTimeout(emitChangeTimeout);
            emitChangeTimeout = setTimeout(emitTextChange, 80);
          });

          ['click', 'keyup', 'mouseup'].forEach((evt) => {
            editor.addEventListener(evt, () => {
              updateCursorInfo();
              emitCursorMove();
              renderCollaborators();
            });
          });

          editor.addEventListener('scroll', renderRemoteCursors);
          document.addEventListener('selectionchange', () => {
            if (document.activeElement !== editor) return;
            updateCursorInfo();
            emitCursorMove();
          });

          updateCursorInfo();
          setSaveStatus('Autosave: idle');
        }

        if (copyBtn && editor) {
          copyBtn.addEventListener('click', async () => {
            try {
              if (navigator.clipboard && navigator.clipboard.writeText) {
                await navigator.clipboard.writeText(getEditorText());
              } else if (hiddenTextarea) {
                hiddenTextarea.style.display = 'block';
                hiddenTextarea.select();
                document.execCommand('copy');
                hiddenTextarea.style.display = 'none';
                editor.focus();
              }
              copyBtn.textContent = 'Copied!';
              setTimeout(() => { copyBtn.textContent = 'Copy'; }, 1500);
            } catch (_) {}
          });
        }

        socket.on("connect", () => {
          socket.emit("text:join", { textId });
        });

        socket.on("text:init", (payload) => {
          if (!editor) return;
          selfUserId = payload.self ? payload.self.id : null;
          collaborators = payload.participants || [];
          if (typeof payload.content === 'string') {
            editor.textContent = payload.content;
            syncHiddenTextarea();
            lastSavedContent = payload.content;
            updateCursorInfo();
          }
          renderCollaborators();
          setActivity('Connected to live collaboration');
        });

        socket.on("text:remote", ({ content, participant }) => {
          if (!editor || typeof content !== 'string') return;
          const currentOffset = getCursorPosition();
          isApplyingRemote = true;
          editor.textContent = content;
          syncHiddenTextarea();
          setCursorPosition(Math.min(currentOffset, content.length));
          isApplyingRemote = false;
          lastSavedContent = content;
          updateCursorInfo();
          renderRemoteCursors();
          if (participant && participant.name) {
            setActivity(`${participant.name} edited the document`);
          }
        });

        socket.on("cursor:remote", (participant) => {
          collaborators = collaborators.map((user) =>
            user.id === participant.id ? participant : user
          );
          renderCollaborators();
        });

        socket.on("presence:joined", (participant) => {
          setActivity(`${participant.name} joined`);
        });

        socket.on("presence:left", (participant) => {
          setActivity(`${participant.name} left`);
        });

        socket.on("presence:list", (participants) => {
          collaborators = participants || [];
          renderCollaborators();
        });

        const form = document.getElementById('textForm');
        if (form) {
          form.addEventListener('submit', () => {
            syncHiddenTextarea();
          });
        }
      });

      document.addEventListener('keydown', function(event) {
        if ((event.ctrlKey || event.metaKey) && event.key === 's') {
          event.preventDefault();
          const form = document.getElementById('textForm');
          if (form) form.submit();
        }
      });
    </script>
    <%- include('./partials/footer.ejs') %>
</body>
</html>
